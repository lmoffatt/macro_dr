model = load_model("scheme_1")
parameter = load_parameters(model, "../data/scheme_1_PI_par.csv")
par_tr = get_standard_parameter_transformed_values(parameter)

experiment = create_experiment(
    experiment_structure=[{1,10,10.0}],
    frequency_of_sampling=50e3,
    initial_agonist=0.0,
    initial_time=0.0)
observations = set_observations(values_set=[0.0])
simulation = simulate(model=model, parameter_values=par_tr, experiment=experiment, observations=observations, number_of_substeps=1, seed=0)

macro_IRV = build_likelihood_function(
    model=model,
    adaptive_approximation=0,
    recursive_approximation=1,
    averaging_approximation=2,
    variance_approximation=1,
    taylor_variance_correction=0)

likelihood = calc_likelihood(
    likelihood_algorithm=macro_IRV,
    parameters=par_tr,
    experiment=experiment,
    data=observations)

dlikelihood_predictions = calc_dlikelihood_predictions(
    likelihood_algorithm=macro_IRV,
    parameters=par_tr,
    experiment=experiment,
    data=simulation)
