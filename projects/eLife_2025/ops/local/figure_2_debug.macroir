# taylor_qdt_approximation is a fossil: micro_* now builds micro Qdt via the
# monoid-potentiation lift (legacy/micro_monoid.h) — macro Qdt is computed at the
# well-conditioned k×k level and combinatorially lifted to microstate
# granularity (no per-micro expm), superseding the old Taylor/Schur micro-Q
# workarounds for the lifted-Q ill-conditioning. So it stays false for all
# algorithms; micro is selected by micro_approximation, not by this flag.
#algo_taylor_qdt_approximation = indexed_bool_by(axis= algorithm_axis,
#    values=[ false, false,false, false])#,   true, true, true])

algorithms = build_likelihood_function(model = model,
            adaptive_approximation     = false,
            recursive_approximation    = algo_recursive_approximation,
            averaging_approximation    = algo_averaging_approximation,
           #                                values=[ 0 ,0, 1, 1, 2]),
           #                               values=[0, 0, 1, 1, 1, 2, 2]),#,   0, 1, 2]),
            variance_approximation     = true,
            taylor_variance_correction = algo_taylor_approximation,
            micro_approximation        = algo_micro_approximation,
            taylor_qdt_approximation   = false )#algo_taylor_qdt_approximation)




dlikelihood_predictions = calc_dlikelihood_predictions(likelihood_algorithm =algorithms, parameters=par_tr, experiment =experiment,
data_series = simulations)

#dlikelihood_file = write_csv(experiment= experiment, simulations = simulations, likelihood = dlikelihood_predictions,
#   path= concat(filepath_run,"_dlikelihoods"))

# h_rel_value: step-size (relative) for the central-diff Fisher.
# Dispatcher injects `--h_rel_value = <value>`; keep commented so the
# in-file definition does not clobber the injection.
# h_rel_value = 1e-5

# Numerical (observed) Fisher information per simulation: F_b is the H reference
# for the IDM and feeds the new Likelihood_Gaussian_Fisher_Distortion diagnostic. Cost:
# 2·n_params extra dlikelihood passes per selected simulation. `decimate=K`
# evaluates F on every K-th simulation only — F's bootstrap is independent of
# dy's, so a sparser F vector still gives a valid bootstrap.
numerical_fisher_information = calc_numerical_fisher_information(
    likelihood_algorithm = algorithms, parameters = par_tr, experiment = experiment,
    data_series = simulations, h_rel = h_rel_value, decimate = 1)


dlikelihood_file = write_csv(
    dlikelihood_predictions = dlikelihood_predictions,
    numerical_fisher_information = numerical_fisher_information,
    path = concat(filepath_run, "_replicates"))


# Per-replica per-sample numerical Fisher Information (DIAGNOSTIC).
# Decomposes the global F into per-timestep contributions F_t. By logL
# additivity, Σ_t F_t equals the global numerical_fisher_information per
# replica. Used for bug-hunting which timestep triggers FD instabilities in
# score derivatives along specific parameter directions (Current_Noise /
# Current_Baseline directions show isolated-replica blowups in the global F).
#
# Cost: 2·n_params extra dlikelihood passes (batched across replicas, shared
# FuncMap_St cache). Output CSV size scales as n_replicas × n_timesteps × p²
# — keep nsim small for the debug runs (8-64).
per_sample_F = calc_per_sample_numerical_fisher_information(
    likelihood_algorithm = algorithms,
    parameters = par_tr,
    experiment = experiment,
    data_series = simulations,
    h_rel = h_rel_value)

# write_csv(experiment, simulations, per_sample_F, path): with load_simulations
# now returning Indexed, BOTH simulations and per_sample_F are Indexed → the DSL
# matches the (Indexed-sims, Indexed-states) overload directly (no lifting) →
# emit_state_rows_with_experiment populates axis columns + agonist + patch_current
# + time per sample, plus the per-timestep F.
per_sample_F_file = write_csv(
    experiment = experiment,
    simulations = simulations,
    likelihood = per_sample_F,
    path = concat(filepath_run, "_per_sample_F"))


# Per-sample detailed derivative dump lives in figure_2_debug_samples.macroir
# (the focused, self-contained script), not here.


likelihood_analysis = likelihood_derivative_basic_diagnostics_paired(
    dlikelihood_predictions = dlikelihood_predictions,
    numerical_fisher_information = numerical_fisher_information,
    n_boostrap_samples = 100,
    probits = [ 0.025, 0.16, 0.5, 0.84, 0.975 ] , seed=0, max_lag=10,
    samples_dir = filepath_run )


likelihood_analysis_res = write_csv(analysis = likelihood_analysis,
   path= concat(filepath_run,"_analysis"))
