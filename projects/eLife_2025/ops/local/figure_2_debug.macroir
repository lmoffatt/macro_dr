)





# Single interval 0.01: the last column of the 7-interval production arrays
# (step 200/400/400, samples 5/5/5). Matches the regenerated single-interval data.
experiment = create_experiment(
   experiment_structure=[
      {indexed_size_by(axis= axis_interval,values=[200]),indexed_size_by(axis= axis_interval,values=[5]),0.0},
      {indexed_size_by(axis= axis_interval,values=[400]),indexed_size_by(axis= axis_interval,values=[5]),10.0},
      {indexed_size_by(axis= axis_interval,values=[400]),indexed_size_by(axis= axis_interval,values=[5]),0.0}
      ],
frequency_of_sampling = 50e3,
initial_agonist = 0.0,
initial_time = 0.0)
                                
observations = set_observations(values_set= [0,0,0,0])

par_tr = get_standard_parameter_transformed_values(parameter)
 
# model_str defined at top (drives the filename infix)

simulation_axis = axis(name= "simulation_algorithm", labels= ["uniformization"])


# === DEBUG: load PRE-EXISTING simulations from a previous run instead of
# generating fresh ones. This keeps the SICK replica (index 44 in the
# referenced CSV) and SANE comparators (0, 1, 5, 10) consistent across runs
# of this script — simulate() with seed=0 → random_device produces a
# different set of replicas every time, which would erase the specific
# trajectory we're hunting in.
# Hardcoded path (edit when targeting a different reference run) and
# hardcoded indices (inline literal — DSL infers vector<size_t> from
# load_simulations' signature). The DSL requires string args to be bound to
# a variable first (const-ref param); literal strings inline don't pass
# the borrow check.
debug_simulation_csv_path = "/home/lmoffatt/Code/macro_dr/macro_dr/projects/eLife_2025/figures/data/figure_2_nch_10000_nsim_64_macro_IR_noise_0.1_h_1e-6_simulation.csv"
simulations = load_simulations(
    filename = debug_simulation_csv_path,
    replica_indices = [0, 1, 2, 3, 48])

# NO _simulation re-emit here: it would write to the SAME path load_simulations
# reads from (concat(filepath_run,"_simulation") == debug_simulation_csv_path),
# destroying the source. The debug script reads _simulation but never writes it.



