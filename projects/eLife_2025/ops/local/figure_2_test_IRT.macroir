# Minimal reproducer for the macro_IRT canary failures observed in figure_2.
# Sweeps only the N values and intervals where IRT failed (per the error
# list), with reduced n_simulations for fast turnaround. Only the macro_IRT
# algorithm is wired so we get a clean trace of where the rank-1
# quasi-Laplace update produces invalid probabilities/covariances.

model = load_model("scheme_CO")

# Cover the failure modes:
#   N=1,10  + interval=1,0.5  → to_Probability negative entries
#   N=100,1000  + interval=0.5,0.2,0.1 → to_Covariance_Probability negative diag
#   N=1000  + interval=0.2 (k=21) → worst negative entry observed (-2.47)
#   N=10000 + interval=0.2,0.1 → derivative-tracking issues
axis_interval = axis(name= "interval_in_tau", labels= ["1", "0.5","0.2","0.1"])
axis_noise    = axis(name= "noise_in_conductance_tau", labels= ["1"])
axis_Nchanels = axis(name= "Num_ch", labels= ["1","10","100","1000","10000"])

current_noise = indexed_double_by(axis= axis_noise,    values= [0.001])
Num_ch        = indexed_double_by(axis= axis_Nchanels, values= [1,10,100,1000,10000])

parameter = create_parameters(
   model = model,
   parameters_info= [
      {"on","Log10",10},
      {"off","Log10",100},
      {"unitary_current","Log10",1},
      {"Current_Noise","Log10",current_noise},
      {"Current_Baseline","Log10",1},
      {"Num_ch_mean","Log10", Num_ch}]
)

experiment = create_experiment(
   experiment_structure=[
      {indexed_size_by(axis= axis_interval,values=[2,4,10,20]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),0.0},
      {indexed_size_by(axis= axis_interval,values=[4,8,20,40]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),10.0},
      {indexed_size_by(axis= axis_interval,values=[4,8,20,40]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),0.0}
      ],
   frequency_of_sampling = 50e3,
   initial_agonist = 0.0,
   initial_time = 0.0)

observations = set_observations(values_set= [0,0,0,0])

par_tr = get_standard_parameter_transformed_values(parameter)

simulation_axis = axis(name= "simulation_algorithm", labels= ["uniformization"])

# 32 simulations is enough to trigger the same canary failures as the full
# 1024 batch — failures are deterministic once the dynamics enter the
# pathological region. Same seed=0 for reproducibility.
simulations = simulate(model= model, parameter_transformed = par_tr,
   n_simulations= 32, experiment = experiment,
   observations = observations,
   simulation_algorithm = indexed_string_by(axis= simulation_axis, values=["uniformization"]),
   number_of_substeps   = indexed_size_by(axis=simulation_axis,values= [1000]),
   seed = 0)

# Only macro_IRT — the failing algorithm.
algorithm_axis = axis(name= "algorithm", labels= ["macro_IRT"])
algo_recursive_approximation  = indexed_bool_by(axis= algorithm_axis, values=[true])
algo_taylor_approximation     = indexed_bool_by(axis= algorithm_axis, values=[true])
algo_micro_approximation      = indexed_bool_by(axis= algorithm_axis, values=[false])
algo_taylor_qdt_approximation = indexed_bool_by(axis= algorithm_axis, values=[false])

algorithms = build_likelihood_function(model = model,
   adaptive_approximation     = false,
   recursive_approximation    = algo_recursive_approximation,
   averaging_approximation    = indexed_int_by(axis= algorithm_axis, values=[2]),
   variance_approximation     = true,
   taylor_variance_correction = algo_taylor_approximation,
   micro_approximation        = algo_micro_approximation,
   taylor_qdt_approximation   = algo_taylor_qdt_approximation)

dlikelihood_predictions = calc_dlikelihood_predictions(
   likelihood_algorithm = algorithms, parameters = par_tr, experiment = experiment,
   data_series = simulations)
