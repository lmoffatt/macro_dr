#    labels= [ "macro_MR", "macro_MRT","macro_IR", "macro_IRT"])
 
#algorithm_axis = axis(name= "algorithm",
#    labels= [ "macro_MR", "macro_IR"])
algorithm_axis = axis(name= "algorithm",
    labels= [ "macro_IR"])


#algorithm_axis = axis(name= "algorithm",
 #   labels= ["macro_NR", "macro_R", "macro_MNR", "macro_MR",  "macro_IR"])
    #,
