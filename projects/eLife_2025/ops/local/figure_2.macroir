#algo_micro_approximation     = indexed_bool_by(axis= algorithm_axis,
#    values=[false, false,false, false])#,   true, true, true])
# Force Taylor + scaling/squaring expm for micro Q (avoids eigen path's
# eigenvector-derivative ill-conditioning at Nch ≥ ~10 in k=2). Macro paths
# stay on eigen since their Q is k×k and well-conditioned.
#algo_taylor_qdt_approximation = indexed_bool_by(axis= algorithm_axis,
#    values=[ false, false,false, false])#,   true, true, true])

algorithms = build_likelihood_function(model = model,
            adaptive_approximation     = false,
            recursive_approximation    = algo_recursive_approximation,
            averaging_approximation    = indexed_int_by(axis= algorithm_axis,
                                           values=[ 2]),
           #                                values=[ 0 ,0, 1, 1, 2]),
           #                               values=[0, 0, 1, 1, 1, 2, 2]),#,   0, 1, 2]),
            variance_approximation     = true,
            taylor_variance_correction = false, #algo_taylor_approximation,
            micro_approximation        = false, #algo_micro_approximation,
            taylor_qdt_approximation   = false )#algo_taylor_qdt_approximation)




dlikelihood_predictions = calc_dlikelihood_predictions(likelihood_algorithm =algorithms, parameters=par_tr, experiment =experiment,
data_series = simulations)

#dlikelihood_file = write_csv(experiment= experiment, simulations = simulations, likelihood = dlikelihood_predictions,
#   path= concat(filepath_run,"_dlikelihoods"))

# Numerical (observed) Fisher information per simulation: F_b is the H reference
# for the IDM and feeds the new Gaussian_Fisher_Distortion diagnostic. Cost:
# 2·n_params extra dlikelihood passes per selected simulation. `decimate=K`
# evaluates F on every K-th simulation only — F's bootstrap is independent of
# dy's, so a sparser F vector still gives a valid bootstrap.
numerical_fisher_information = calc_numerical_fisher_information(
    likelihood_algorithm = algorithms, parameters = par_tr, experiment = experiment,
    data_series = simulations, h_rel = 1e-5, decimate = 1)


likelihood_analysis = likelihood_derivative_basic_diagnostics_paired(
    dlikelihood_predictions = dlikelihood_predictions,
    numerical_fisher_information = numerical_fisher_information,
    n_boostrap_samples = 100,
    probits = [ 0.025 , 0.975 ] , seed=0, max_lag=10,
    samples_dir = filepath_run )


likelihood_analysis_res = write_csv(analysis = likelihood_analysis,
   path= concat(filepath_run,"_analysis"))
