parameter = create_parameters(
   model = model, 
   parameters_info= [   
      {"on","Log10",10},
{"off","Log10",100},
{"unitary_current","Log10",1},
{"Current_Noise","Log10",current_noise},
{"Current_Baseline","Log10",1},
{"Num_ch_mean","Log10", Num_ch}]
)





experiment = create_experiment(
   experiment_structure=[
      {indexed_size_by(axis= axis_interval,values=[2,4,10,20,40,100,200]),indexed_size_by(axis= axis_interval,values=[500,250,100,50,25,10,5]),0.0},
      {indexed_size_by(axis= axis_interval,values=[4,8,20,40,80,200,400]),indexed_size_by(axis= axis_interval,values=[500,250,100,50,25,10,5]),10.0},
      {indexed_size_by(axis= axis_interval,values=[4,8,20,40,80,200,400]),indexed_size_by(axis= axis_interval,values=[500,250,100,50,25,10,5]),0.0}
     # {indexed_size_by(axis= axis_interval,values=[2,4,10,20]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),0.0},
     # {indexed_size_by(axis= axis_interval,values=[4,8,20,40]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),10.0},
     # {indexed_size_by(axis= axis_interval,values=[4,8,20,40]),indexed_size_by(axis= axis_interval,values=[500,250,100,50]),0.0}
     #  {indexed_size_by(axis= axis_interval,values=[2,20]),indexed_size_by(axis= axis_interval,values=[500,50]),0.0},
     #  {indexed_size_by(axis= axis_interval,values=[4,40]),indexed_size_by(axis= axis_interval,values=[500,50]),10.0},
     #  {indexed_size_by(axis= axis_interval,values=[4,40]),indexed_size_by(axis= axis_interval,values=[500,50]),0.0}
      ], 
frequency_of_sampling = 50e3,
initial_agonist = 0.0, 
initial_time = 0.0)
                                
observations = set_observations(values_set= [0,0,0,0])

par_tr = get_standard_parameter_transformed_values(parameter)
 
# model_str defined at top (drives the filename infix)

simulation_axis = axis(name= "simulation_algorithm", labels= ["uniformization"])


simulations =  simulate(model= model, parameter_transformed = par_tr, n_simulations= n_simulations, experiment = experiment,
                         observations = observations, 
                         simulation_algorithm= indexed_string_by(axis= simulation_axis, values=["uniformization"]),
                         number_of_substeps = indexed_size_by(axis=simulation_axis,values= [1000]),
                 seed = 0)



simulation_file = write_csv(experiment= experiment, simulations=simulations,
   path= concat(filepath_run,"_simulation"))



